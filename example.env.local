# Usado pelo CI (npm run build:e2e) e como referencia para desenvolvimento local.
# Na CI o backend sobe na porta 3001 (ver .github/workflows/e2e.yml).
NEXT_PUBLIC_API_URL=http://localhost:3001

NEXT_PUBLIC_IS_GOOGLE_AUTH_ENABLED=false
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

NEXT_PUBLIC_IS_SIGN_UP_ENABLED=true

# Suporta "local", "s3", "s3-presigned"
NEXT_PUBLIC_FILE_DRIVER=local
